# SprintCycle environment templates
# Copy to .env and adjust for your environment.

# -----------------------------------------------------------------------------
# Shared runtime
# -----------------------------------------------------------------------------
SPRINTCYCLE_ENV=production
SPRINTCYCLE_SERVICE=dashboard
PROJECT_PATH=/workspace
PYTHONUNBUFFERED=1

# Optional: if you run the backend behind a different origin or reverse proxy
# FRONTEND_ORIGIN=https://sprintcycle.example.com
# API_PUBLIC_BASE_URL=https://sprintcycle.example.com/api

# -----------------------------------------------------------------------------
# Local development (backend / frontend compose)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Production edge / TLS
# -----------------------------------------------------------------------------
# DOMAIN=sprintcycle.example.com
# ACME_EMAIL=admin@example.com
# TLS_CERT_PATH=/etc/letsencrypt/live/sprintcycle.example.com/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/sprintcycle.example.com/privkey.pem

# -----------------------------------------------------------------------------
# Persistence / data paths
# -----------------------------------------------------------------------------
# SPRINTCYCLE_DATA_DIR=./.sprintcycle
# CACHE_DIR=./cache
