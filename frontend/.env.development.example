# Copy to .env.development (gitignored). Defaults align with
# ``DashboardPortDefaults`` in sprintcycle/config/runtime_config.py.

# Vite dev server port (``sprintcycle dashboard --dev`` sets this for the child process).
VITE_DEV_SERVER_PORT=5173

# Origin of the FastAPI backend for /api proxy (must match ``dashboard --port``).
VITE_PROXY_TARGET=http://127.0.0.1:8080
