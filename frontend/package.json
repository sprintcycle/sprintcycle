{
  "name": "sprintcycle-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "openapi:dump": "cd .. && python scripts/export_dashboard_openapi.py -o frontend/openapi-dashboard.json",
    "openapi:types": "openapi-typescript openapi-dashboard.json -o src/api/openapi-gen.ts",
    "openapi:sync": "npm run openapi:dump && npm run openapi:types",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "element-plus": "^2.8.8",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "eslint-plugin-vue": "^9.32.0",
    "openapi-typescript": "^7.4.4",
    "prettier": "^3.4.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.2",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^6.0.3",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.10"
  }
}
