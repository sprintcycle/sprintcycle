# SprintCycle 项目配置示例（复制为 sprintcycle.toml 后按需修改）
# 环境变量 SPRINTCYCLE_* 可覆盖同名字段
#
# 普通产品迭代默认方向（与 RuntimeConfig 无文件时一致）：
# - quality.level=L2：静态门禁 + pytest + 覆盖率，便于自动化测试与回归
# - storage.backend=sqlite：执行状态与 knowledge_cards 默认同库，单机自闭环
# - 技术栈约定见 release_plan/templates/normal_task.yaml 与
#   release_plan/templates/governance_product_iteration.example.yaml

[project]
path = "."
parallel_tasks = 3
max_sprints = 10

[quality]
level = "L2"
# 预设档位（V4.0 §6.3）：default | off | fast | strict
# - fast → 等效 L1（速写原型）
# - strict → 等效 L3（+ 架构 import-linter 等）
# profile = "strict"
min_coverage_percent = 80.0

[execution]
max_verify_fix_rounds = 3

[engine]
# 编码引擎: aider | claude_code | cursor_cookbook | 其他字符串回退 LiteLLM
# Claude Code: 本机需 ``claude`` CLI，见 docs/CODING_ENGINES_CLAUDE_CURSOR.md
# Cursor Cookbook: 写 .sprintcycle/cursor-cookbook/*.md；可选 SPRINTCYCLE_CURSOR_USE_CLI=1 调 agent
name = "aider"

[llm]
provider = "deepseek"
model = "deepseek-reasoner"

[storage]
# 执行状态：json（仅文件、无 DB）或 sqlite（推荐产品迭代）
backend = "sqlite"
state_dir = ".sprintcycle/state"
# sqlite 时 executions + knowledge_cards 共用此文件（相对路径相对项目根）
sqlite_path = ".sprintcycle/data/sprintcycle.db"

# [hitl]
# 人机卡点（默认关闭）：在 Sprint/任务边界阻塞等待 Dashboard / CLI / MCP 决策
# enabled = true
# gates = "before_sprint"   # 逗号分隔: before_sprint, after_sprint, after_task
# default_timeout_seconds = 300
# timeout_behavior = "approve"   # approve | abort_execution | skip_sprint
# after_task_on_failure = true
# after_sprint_always = false
# db_path = ".sprintcycle/hitl.db"

# [cache]
# 统一执行缓存（默认 diskcache；多实例部署可改为 redis）
# 完整说明见 docs/CACHE.md；环境变量可用 SPRINTCYCLE_CACHE_BACKEND、SPRINTCYCLE_CACHE_ENABLED 等覆盖
# enabled = true
# backend = "diskcache"   # 或 "redis"
# dir = ".sprintcycle/cache"
# redis_url = "redis://localhost:6379/0"
# url = "redis://..."     # 与 redis_url 等价（任选其一）
# max_entries = 1000
# default_ttl_hours = 24
# llm_codegen = true     # Coder 成功生成结果是否写入 ExecutionCache

# [behavior]
# V4.0：知识注入落盘前需显式确认（API confirm_knowledge / CLI --yes）
# require_knowledge_injection_confirm = false
# Sprint 结束后写入 knowledge_cards 结构化摘要
# persist_sprint_knowledge_cards = true

# ── 「开箱即审」保守组合（仅观察：不阻断 Planning / Review；CLI 不因 error 退出）──
# 复制本段到 sprintcycle.toml 即可；可选复制 governance_product_iteration.example.yaml
# 为 .sprintcycle/governance.yaml 并在下方填写 config_path。
[governance]
enabled = true
block_on = "none"
# 无文件亦可：仅跑内置 Planning/Review 包；有文件时合并 YAML 中的 planning/review/task_after
# config_path = ".sprintcycle/governance.yaml"
# 将聚合结果中的 error 一律降为 warning（仍写入报告与日志）
downgrade_errors_to_warnings = true
run_static = true
run_import_linter = true
check_adr = false
check_compose = false
# spec_glob = "docs/specs/*.md"   # 未匹配时本就为 warning；block_on=none 时不阻断 Sprint
# task_hooks = false              # 任务级 task_after 默认关，避免每任务子进程开销

# 若需 CI 硬失败，改用 block_on = "review_only" 并设 downgrade_errors_to_warnings = false
